network:
  version: 2
  ethernets:
    eno8303:
      dhcp4: false
    eno8403:
      dhcp4: false
  bridges:
    mgmtbr:
      interfaces: [eno8303]
      addresses: [{{ kayobehost_mgmt_ip }}/{{ management_netmask }}]
      gateway4: {{ management_gw }}
      nameservers:
        addresses: [{{ management_dns }}]
      dhcp4: false
    idracbr:
      interfaces: [eno8403]
      addresses: [{{ kayobehost_idrac_ip }}/{{ idrac_netmask }}]
      dhcp4: false

